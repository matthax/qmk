{
  "name": "qmk",
  "version": "0.1.2",
  "description": "QMK API bindings. Get information on keyboards, compile firmware and more",
  "repository": "https://github.com/matthax/qmk",
  "license": "MIT",
  "workspaces": [
    "packages/*",
    "examples"
  ],
  "keywords": [
    "qmk",
    "node",
    "browser",
    "keyboard",
    "api",
    "firmware"
  ],
  "scripts": {
    "build": "bun run --filter '@qmk/*' build",
    "test": "bun run --filter '@qmk/*' test",
    "clean": "bun run --filter '*' clean",
    "fix": "eslint --fix \"packages/*/src/**/*.ts\" \"examples/**/*.ts\"",
    "lint": "eslint \"packages/*/src/**/*.ts\" \"examples/**/*.ts\""
  },
  "engines": {
    "node": ">=24",
    "bun": ">=1.0"
  },
  "devDependencies": {
    "@anthropic-ai/claude-code": "^2.1.101",
    "@bitjson/npm-scripts-info": "^1.0.0",
    "@istanbuljs/nyc-config-typescript": "^1.0.2",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "ava": "^7.0.0",
    "cz-conventional-changelog": "^3.3.0",
    "eslint": "^10.2.0",
    "gh-pages": "^6.3.0",
    "globals": "^17.4.0",
    "npm-run-all2": "^8.0.4",
    "nyc": "^18.0.0",
    "open-cli": "^9.0.0",
    "standard-version": "^9.5.0",
    "trash-cli": "^7.2.0",
    "tsx": "^4.21.0",
    "typedoc": "^0.28.18",
    "typescript": "^6.0.2"
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  }
}
