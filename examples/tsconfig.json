{
  "compilerOptions": {
    "target": "es2022",
    "rootDir": ".",
    "outDir": "build",
    "moduleResolution": "node",
    "module": "commonjs",
    "declaration": false,
    "esModuleInterop": true,
    "strict": true,
    "lib": ["es2022", "dom"],
    "types": [],
    "typeRoots": ["../node_modules/@types"],
    "paths": {
      "@qmk/core": ["../packages/core/src/index.ts"]
    }
  },
  "include": ["./**/*.ts"],
  "exclude": ["node_modules/**", "build/**"]
}
